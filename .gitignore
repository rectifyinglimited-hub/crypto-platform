**/build/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Logs / cache
*.log
.cache/

# Temp / scratch
_touch.tmp

# Uploaded deposit proofs
uploads/
backend/uploads/
